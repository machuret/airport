{
  "buildCommand": "pip install --upgrade pip && python3 scripts/generate.py --clean",
  "outputDirectory": "dist",
  "installCommand": "pip3 install --upgrade pip",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)/", "destination": "/$1/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
