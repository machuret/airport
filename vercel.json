{
  "buildCommand": "python3 scripts/generate.py --clean",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)/", "destination": "/$1/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
